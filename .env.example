# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...       # Claude Opus 4.6 for chat + insights
OPENAI_API_KEY=sk-proj-...               # text-embedding-3-small for vector search

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=personal_brain
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Tools (Optional) ─────────────────────────────────────────────────────────
